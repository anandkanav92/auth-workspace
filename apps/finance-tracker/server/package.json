    "node-cron": "^4.2.1",
    "pdfjs-dist": "^4.5.0",
    "pocketbase": "^0.23.0",
    "yahoo-finance2": "^3.15.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.7.0",
