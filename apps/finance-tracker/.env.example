# finance-tracker — environment template (M16.1)
#
# Copy to `.env` (gitignored) and fill in real values on the deploy host.
# NEVER commit the filled-in `.env` — it holds the PocketBase superuser
# credentials, the Firebase service-account JSON, and the Finnhub key.
#
# Two groups:
#   SERVER (process.env.*)  — read at runtime by the BFF container.
#   WEB    (VITE_* / import.meta.env.*) — baked into the SPA bundle at BUILD time
#                                         by Vite, so they must ALSO be passed as
#                                         docker build args (see docker-compose.yml).
# Derived by grepping `server/src` for `process.env.` and `web/src` for
# `import.meta.env.` — keep this file in sync if either list changes.

# ====================================================================
# SERVER (BFF) — runtime
# ====================================================================

# Base URL of finance-tracker's OWN PocketBase the BFF talks to. finance-tracker
# now ships its own PocketBase container (it is NOT shared with other apps) —
# `finance-pocketbase` is its service name on the private `finance-net` network
# in docker-compose.yml. The host maps it on port 8092, but inside the network
# the BFF reaches it on 8090.
PB_URL=http://finance-pocketbase:8090

# Long-lived PocketBase superuser impersonation token (optional). If set, the
# BFF uses it and ignores PB_ADMIN_EMAIL/PASSWORD below. For THIS self-contained
# deploy you normally leave this BLANK and rely on the superuser credentials
# instead (see below).
PB_ADMIN_TOKEN=

# PocketBase superuser credentials. For this deploy these are REQUIRED: the
# finance-pocketbase container upserts this superuser on boot (start.sh reads
# them as PB_EMAIL/PB_PASSWORD), and the BFF authenticates with the SAME creds
# when PB_ADMIN_TOKEN is blank. Set both to the same value the container seeds.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=replace-with-a-strong-password

# Firebase Admin service-account, as a single-line JSON string (the full
# downloaded service-account key). Used to verify Firebase ID tokens server-side.
# Keep on ONE line; escape inner quotes as needed for the .env format.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Finnhub API key — used by the fallback price provider when Yahoo returns null.
# Free tier is sufficient for v1. Get one at https://finnhub.io.
FINNHUB_API_KEY=replace-with-finnhub-api-key

# Sentry DSN for server-side error tracking. Leave BLANK to disable (no-op
# locally and in any instance without observability).
SENTRY_DSN=

# Enable background cron jobs (hourly prices, daily FX, nightly snapshots,
# weekly profile refresh + snapshot prune). Set to `true` on EXACTLY ONE
# deployed instance; leave unset/`false` everywhere else (dev, CI, replicas).
CRON_ENABLED=true

# HTTP port the BFF listens on INSIDE the container. The Docker image sets
# PORT=80 and docker-compose maps host 3110 -> container 80, so you normally
# leave this unset in `.env`. Defaults to 3110 when run outside Docker.
# PORT=3110

# ====================================================================
# WEB (SPA) — build-time (Vite). These must be present at `docker compose build`
# time because Vite inlines them into the bundle. docker-compose.yml forwards
# each one as a build arg.
# ====================================================================

# Firebase web app config (public — safe to expose in the client bundle).
# From Firebase Console -> Project settings -> Your apps -> SDK setup.
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Optional Firebase web config fields. Safe to leave blank for Google sign-in
# only; fill if you later use Cloud Storage / Cloud Messaging.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Optional explicit BFF base URL for the SPA. Leave BLANK in the single-container
# prod deploy and in dev — the SPA then uses same-origin relative `/api/*` paths
# (prod serves the SPA from the BFF; Vite proxies `/api` to :3110 in dev).
VITE_API_BASE_URL=

# Sentry DSN for browser-side error tracking. Leave BLANK to disable.
VITE_SENTRY_DSN=
