{
  "name": "finance-tracker",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --parallel /^dev:/",
    "dev:web": "pnpm --filter ./web dev",
    "dev:server": "pnpm --filter ./server dev",
    "build": "pnpm --filter ./web build && pnpm --filter ./server build",
    "test": "pnpm --recursive test"
  }
}
