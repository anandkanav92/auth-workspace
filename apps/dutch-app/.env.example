# Firebase Auth (baked into Next.js build at compile time)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# PocketBase URL (browser-facing — use tunnel URL in production)
NEXT_PUBLIC_PB_URL=

# PocketBase admin credentials (used by start.sh to bootstrap)
PB_EMAIL=
PB_PASSWORD=
