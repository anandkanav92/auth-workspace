# Use the public npm registry so the workspace builds without the Spotify VPN.
# All deps here are public OSS (no private @spotify packages), and the pnpm
# lockfile stores integrity hashes only — public npm serves identical artifacts
# to Artifactory's virtual-npm proxy. Overrides the global ~/.npmrc registry
# for this workspace only.
registry=https://registry.npmjs.org/

approve-builds[]=@firebase/util
approve-builds[]=esbuild
approve-builds[]=protobufjs
